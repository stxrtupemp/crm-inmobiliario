# ══════════════════════════════════════════════════════════════════
#  CRM Inmobiliario — Environment Variables
#  Copy this file to .env and fill in the values for your environment.
#  NEVER commit .env to source control.
# ══════════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=crm_db

# ── Server ────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ── Database connection ───────────────────────────────────────────
# In Docker Compose, use host = service name: postgres
# Locally, use: localhost
DATABASE_URL=postgresql://crm_user:change_me_in_production@localhost:5432/crm_db

# ── JWT ───────────────────────────────────────────────────────────
# Minimum 32 characters. Generate with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_of_at_least_32_chars
JWT_REFRESH_SECRET=replace_with_a_different_long_random_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── File uploads ──────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# ── Security ──────────────────────────────────────────────────────
# bcrypt rounds: 10 (dev/fast) | 12 (balanced) | 14 (prod/slow)
BCRYPT_ROUNDS=12

# ── Client (Vite) ─────────────────────────────────────────────────
VITE_API_URL=http://localhost:4000/api
VITE_PUBLIC_URL=http://localhost:5173
